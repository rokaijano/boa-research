schema_version = 3

[run]
tag = "default"
max_trials = 1
max_consecutive_failures = 3

[agent]
preset = "copilot"
runtime = "cli"
command = "copilot"
model = "gpt-5-mini"
prepare_timeout_seconds = 900
max_output_tokens = 4000
max_agent_steps = 40

[guardrails]
allowed_paths = ["src/mnist_demo/cli.py", "src/mnist_demo/config.py", "src/mnist_demo/data.py", "src/mnist_demo/model.py", "src/mnist_demo/runtime.py", "src/mnist_demo/training.py"]
protected_paths = [".boa/protected", "README.md", ".git", "requirements.txt", "reports/metrics.json", "train.py", "eval.py", "tests/test_smoke.py"]

[git_auth]
token_env = "GIT_TOKEN"
username = "x-access-token"
use_for_local_push = true
use_for_remote_fetch = true

fallback_token_env = "GITHUB_TOKEN"
[runner]
mode = "local"

[runner.local]

[runner.ssh]
port = 22
repo_path = "."
git_remote = "origin"
runtime_root = ".boa/remote"

[runner.scout]
enabled = true
commands = ["python train.py --device cpu", "python eval.py --device cpu"]
timeout_seconds = 1800

[runner.confirm]
enabled = false
commands = []
timeout_seconds = 3600

[runner.promoted]
enabled = false
commands = []
timeout_seconds = 7200

[[metrics]]
name = "accuracy"
source = "json_file"
path = "reports/metrics.json"
json_key = "accuracy"

[objective]
primary_metric = "accuracy"
direction = "maximize"
minimum_improvement_delta = 0.0

[search]
oracle = "bayesian_optimization"
max_history = 50
parent_suggestion_count = 5
family_suggestion_count = 5
knob_region_count = 5
risk_penalty = 0.25
family_bonus = 0.1
lineage_bonus = 0.05
exploration_weight = 0.35
observation_noise = 0.15
